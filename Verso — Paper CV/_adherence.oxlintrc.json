{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/callouts/**",
              "components/contact/**",
              "components/experience/**",
              "components/section/**",
              "components/tags/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|EB Garamond))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, EB Garamond."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|href|onClick|disabled|fullWidth|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, href, onClick, disabled, fullWidth, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|cite|icon|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: variant, title, cite, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:note|quote|aside)$/]",
        "message": "<Callout> variant must be one of 'note' | 'quote' | 'aside'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|href|variant|key|ref|className|style|children)$/]",
        "message": "<ContactLink> doesn't accept that prop. Declared props: icon, label, value, href, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactLink'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:inline|block)$/]",
        "message": "<ContactLink> variant must be one of 'inline' | 'block'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Experience'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|org|orgHref|dates|location|summary|bullets|tags|key|ref|className|style|children)$/]",
        "message": "<Experience> doesn't accept that prop. Declared props: role, org, orgHref, dates, location, summary, bullets, tags."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|ordinal|title|rule|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: label, ordinal, title, rule."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|accent|level|key|ref|className|style|children)$/]",
        "message": "<SkillTag> doesn't accept that prop. Declared props: children, variant, accent, level."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillTag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|solid|ghost)$/]",
        "message": "<SkillTag> variant must be one of 'outline' | 'solid' | 'ghost'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
